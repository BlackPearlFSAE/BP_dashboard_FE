# Override only when FE & BE are on different hosts (e.g. Netlify FE + Render BE):
#   VITE_API_URL=https://blackpearl-ws-8z9a.onrender.com
#   VITE_WS_URL=wss://blackpearl-ws-8z9a.onrender.com/ws?role=dashboard
